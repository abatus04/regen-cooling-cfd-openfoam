FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      sampleDict;
}

type sets;
libs (sampling);

interpolationScheme cellPoint;
setFormat       csv;
fields          (T p U);

sets
{
    wallProfile
    {
        type    uniform;
        axis    y;
        start   (0.05  0.001  0.001);
        end     (0.05  0.004  0.001);
        nPoints 100;
    }

    coolantCenterline
    {
        type    uniform;
        axis    x;
        start   (0.0   0.0025  0.001);
        end     (0.1   0.0025  0.001);
        nPoints 200;
    }

    nearWallLine
    {
        type    uniform;
        axis    x;
        start   (0.0   0.00395  0.001);
        end     (0.1   0.00395  0.001);
        nPoints 200;
    }
}
