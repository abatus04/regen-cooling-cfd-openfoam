5
(
    coolantInlet
    {
        type            patch;
        nFaces          30;
        startFace       5870;
    }
    coolantOutlet
    {
        type            patch;
        nFaces          30;
        startFace       5900;
    }
    frontAndBack
    {
        type            empty;
        inGroups        1(empty);
        nFaces          6000;
        startFace       5930;
    }
    fluid_to_outerWall
    {
        type            mappedWall;
        inGroups        1(wall);
        nFaces          100;
        startFace       11930;
        sampleMode      nearestPatchFace;
        sampleRegion    outerWall;
        samplePatch     outerWall_to_fluid;
    }
    fluid_to_innerWall
    {
        type            mappedWall;
        inGroups        1(wall);
        nFaces          100;
        startFace       12030;
        sampleMode      nearestPatchFace;
        sampleRegion    innerWall;
        samplePatch     innerWall_to_fluid;
    }
)

